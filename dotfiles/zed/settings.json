{
  "format_on_save": "on",

  "theme": "Kanagawa Dragon",
  "icon_theme": "Zed (Default)",
  "base_keymap": "VSCode",
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_size": 16.0,
  "ui_font_family": "JetBrainsMonoNL Nerd Font Propo",
  "ui_font_size": 16.0,
  "image_viewer": {
    "unit": "decimal",
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "hover_popover_enabled": false,
  "restore_on_startup": "launchpad",
  "close_panel_on_toggle": true,
  "when_closing_with_no_tabs": "platform_default",
  "use_system_path_prompts": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },
  "title_bar": {
    "show_branch_icon": false,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_menus": false,
  },
  "middle_click_paste": false,
  "double_click_in_multibuffer": null,
  "gutter": {
    "line_numbers": true,
    "runnables": false,
    "breakpoints": true,
    "folds": false,
    "min_line_number_digits": 3,
  },
  "search": {
    "button": false,
  },
  "use_smartcase_search": true,
  "project_panel": {
    "button": false,
    "drag_and_drop": false,
  },
  "outline_panel": {
    "button": false,
    "dock": "left",
  },
  "collaboration_panel": {
    "button": false,
    "dock": null,
  },
  "git_panel": {
    "button": false,
    "sort_by_path": true,
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2-codex",
      "enable_thinking": false,
    },
    "button": false,
    "default_view": "thread",
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.2-codex",
      "enable_thinking": false,
    },
  },
  "semantic_tokens": "combined",
  "document_symbols": "on",
  "tab_bar": {
    "show": false,
    "show_nav_history_buttons": false,
    "show_pinned_tabs_in_separate_row": false,
  },
  "formatter": "auto",

  "soft_wrap": "editor_width",
  "preferred_line_length": 120,

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "git": {
    "blame": {
      "show_avatar": false,
    },
  },

  "edit_predictions": {
    "provider": "copilot",
    "enabled_in_text_threads": false,
  },

  "journal": {
    "path": "~/weaver",
    "hour_format": "hour12",
  },

  "status_bar": {
    "experimental.show": true,
    "active_language_button": true,
  },

  "terminal": {
    "button": false,
  },

  "auto_install_extensions": {
    "html": true,
    "nix": true,
    "xml": true,
    "dockerfile": true,
  },

  "session": {
    "trust_all_worktrees": true,
  },

  "vim": {
    "use_smartcase_find": true,
  },

  "which_key": {
    "enabled": true,
    "delay_ms": 200,
  },
}
